{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Analysis": {
      "title": "Analysis",
      "description": "Amazon listing optimization analysis",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "url": { "type": "string" },
        "result": { "type": "string" },
        "timestamp": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "url", "result", "timestamp"]
    },
    "AuthorizedEmail": {
      "title": "Authorized Email",
      "description": "Emails allowed to access the platform",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "Form submission from potential clients",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "company": { "type": "string" },
        "phone": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "company", "phone", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Root collection for users"
    },
    "users/{userId}/history/{analysisId}": {
      "schema": "Analysis",
      "description": "User's history of analyses"
    },
    "authorized_emails/{emailId}": {
      "schema": "AuthorizedEmail",
      "description": "List of emails permitted to sign up/in"
    },
    "inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Potential client inquiries"
    }
  }
}
