{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Analysis": {
      "title": "Analysis",
      "description": "Amazon listing optimization analysis",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "url": { "type": "string" },
        "result": { "type": "string" },
        "timestamp": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "url", "result", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Root collection for users"
    },
    "users/{userId}/history/{analysisId}": {
      "schema": "Analysis",
      "description": "User's history of analyses"
    }
  }
}
